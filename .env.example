# ── Server ────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── JWT (generate a long random string for production) ────────────
# Run: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-random-secret

# ── Database ──────────────────────────────────────────────────────
# Leave blank for default path (./server/gir_rituals.db in dev, /data/gir_rituals.db on Render)
DB_PATH=

# ── CORS ──────────────────────────────────────────────────────────
# In production: set to your frontend domain (Netlify, Vercel, etc.)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ── Email / OTP (Nodemailer) ──────────────────────────────────────
# Gmail: enable 2FA, then create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# ── SMS + WhatsApp OTP (Twilio) ───────────────────────────────────
# Create a free account at twilio.com, get a phone number
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your-auth-token
TWILIO_PHONE=+14155552671

# WhatsApp sender number (Twilio Sandbox: +14155238886, or your verified business number)
# Note: Production WhatsApp requires Meta Business verification (~3–5 days)
TWILIO_WHATSAPP_FROM=+14155238886

# ── Razorpay ─────────────────────────────────────────────────────
# Create account at razorpay.com → Settings → API Keys → Generate Key (Test mode first)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# ── Sentry error monitoring ───────────────────────────────────────
# Create project at sentry.io → Settings → Projects → DSN
SENTRY_DSN=https://xxxx@xxxxxx.ingest.sentry.io/xxxxxxx

# ── Frontend env (Vite — prefix with VITE_) ──────────────────────
# Google OAuth: console.cloud.google.com → OAuth 2.0 credentials
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Apple Sign In: developer.apple.com → Certificates → Services IDs
VITE_APPLE_CLIENT_ID=com.yourcompany.girrituals
VITE_APPLE_REDIRECT_URI=https://yourdomain.com

# Razorpay public key (safe to expose to frontend)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Backend URL for frontend (only needed for split deploy e.g. Netlify + Render)
# Leave blank when serving frontend from Express (same origin)
VITE_API_URL=
