# ── Server ────────────────────────────────────────────────────────
PORT=3001

# ── JWT (change this to a long random string in production) ───────
JWT_SECRET=change-me-to-a-random-secret

# ── CORS (comma-separated list of allowed frontend origins) ───────
# For split deploy (Netlify + Render), set this to your Netlify URL
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,https://your-app.netlify.app

# ── Frontend API base (set this in Netlify environment variables) ─
# Leave blank for local dev (Vite proxy handles it)
# In Netlify: set to your Render backend URL e.g. https://gir-rituals-api.onrender.com
VITE_API_URL=

# ── Google OAuth ──────────────────────────────────────────────────
# Get from https://console.cloud.google.com → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── Apple Sign In ─────────────────────────────────────────────────
# Get from https://developer.apple.com → Certificates, Identifiers & Profiles
VITE_APPLE_CLIENT_ID=com.yourcompany.girrituals
VITE_APPLE_REDIRECT_URI=https://yourdomain.com/auth/apple/callback
